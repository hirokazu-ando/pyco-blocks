<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="velapsed">elapsed</variable>
    <variable id="vespeed">espeed</variable>
    <variable id="vey">ey</variable>
  </variables>
  <!-- elapsed = timer.elapsed()  →  espeed = 2 + elapsed // 5  →  ey += espeed -->
  <block type="var_set" x="20" y="20">
    <field name="VAR" id="velapsed">elapsed</field>
    <value name="VALUE">
      <block type="py_module_call_val">
        <field name="MODULE">timer</field>
        <field name="FUNC">elapsed</field>
      </block>
    </value>
    <next>
      <block type="var_set">
        <field name="VAR" id="vespeed">espeed</field>
        <value name="VALUE">
          <block type="py_math_op">
            <field name="OP">+</field>
            <value name="LEFT">
              <block type="val_number"><field name="NUM">2</field></block>
            </value>
            <value name="RIGHT">
              <block type="py_math_op">
                <field name="OP">//</field>
                <value name="LEFT">
                  <block type="val_var"><field name="VAR" id="velapsed">elapsed</field></block>
                </value>
                <value name="RIGHT">
                  <block type="val_number"><field name="NUM">5</field></block>
                </value>
              </block>
            </value>
          </block>
        </value>
        <next>
          <block type="var_change">
            <field name="VAR" id="vey">ey</field>
            <value name="AMOUNT">
              <block type="val_var"><field name="VAR" id="vespeed">espeed</field></block>
            </value>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
