<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vpx">px</variable>
    <variable id="vex">ex</variable>
    <variable id="vey">ey</variable>
    <variable id="vli">lives</variable>
    <variable id="vit">itimer</variable>
    <variable id="vst">state</variable>
  </variables>
  <block type="py_def_noarg" x="20" y="20">
    <field name="NAME">update_play</field>
    <statement name="BODY">
      <block type="pico_if">
        <mutation elseif="0" else="0" />
        <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_RIGHT</field></block></value>
        <statement name="DO0">
          <block type="var_change">
            <field name="VAR" id="vpx">px</field>
            <value name="AMOUNT"><block type="val_number"><field name="NUM">4</field></block></value>
          </block>
        </statement>
        <next>
          <block type="pico_if">
            <mutation elseif="0" else="0" />
            <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_LEFT</field></block></value>
            <statement name="DO0">
              <block type="var_change">
                <field name="VAR" id="vpx">px</field>
                <value name="AMOUNT"><block type="val_number"><field name="NUM">-4</field></block></value>
              </block>
            </statement>
            <next>
              <block type="var_change">
                <field name="VAR" id="vey">ey</field>
                <value name="AMOUNT"><block type="val_number"><field name="NUM">3</field></block></value>
                <next>
                  <block type="pico_if">
                    <mutation elseif="0" else="0" />
                    <value name="IF0">
                      <block type="cond_compare">
                        <field name="OP">&gt;</field>
                        <value name="LEFT"><block type="val_var"><field name="VAR" id="vey">ey</field></block></value>
                        <value name="RIGHT"><block type="val_number"><field name="NUM">400</field></block></value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="var_set">
                        <field name="VAR" id="vey">ey</field>
                        <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                        <next>
                          <block type="var_set">
                            <field name="VAR" id="vex">ex</field>
                            <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                          </block>
                        </next>
                      </block>
                    </statement>
                    <next>
                      <block type="pico_if">
                        <mutation elseif="0" else="0" />
                        <value name="IF0">
                          <block type="cond_and">
                            <value name="A">
                              <block type="game_timer_done">
                                <field name="VAR" id="vit">itimer</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="cond_and">
                                <value name="A">
                                  <block type="cond_compare">
                                    <field name="OP">&lt;</field>
                                    <value name="LEFT">
                                      <block type="py_abs">
                                        <value name="VALUE">
                                          <block type="py_math_op">
                                            <field name="OP">-</field>
                                            <value name="LEFT"><block type="val_var"><field name="VAR" id="vpx">px</field></block></value>
                                            <value name="RIGHT"><block type="val_var"><field name="VAR" id="vex">ex</field></block></value>
                                          </block>
                                        </value>
                                      </block>
                                    </value>
                                    <value name="RIGHT"><block type="val_number"><field name="NUM">40</field></block></value>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="cond_compare">
                                    <field name="OP">&lt;</field>
                                    <value name="LEFT">
                                      <block type="py_abs">
                                        <value name="VALUE">
                                          <block type="py_math_op">
                                            <field name="OP">-</field>
                                            <value name="LEFT"><block type="val_number"><field name="NUM">330</field></block></value>
                                            <value name="RIGHT"><block type="val_var"><field name="VAR" id="vey">ey</field></block></value>
                                          </block>
                                        </value>
                                      </block>
                                    </value>
                                    <value name="RIGHT"><block type="val_number"><field name="NUM">40</field></block></value>
                                  </block>
                                </value>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="var_change">
                            <field name="VAR" id="vli">lives</field>
                            <value name="AMOUNT"><block type="val_number"><field name="NUM">-1</field></block></value>
                            <next>
                              <block type="var_set">
                                <field name="VAR" id="vey">ey</field>
                                <value name="VALUE"><block type="val_number"><field name="NUM">-48</field></block></value>
                                <next>
                                  <block type="var_set">
                                    <field name="VAR" id="vex">ex</field>
                                    <value name="VALUE"><block type="game_random_int"><field name="LO">0</field><field name="HI">576</field></block></value>
                                    <next>
                                      <block type="game_timer_set">
                                        <field name="VAR" id="vit">itimer</field>
                                        <value name="SEC"><block type="val_number"><field name="NUM">1</field></block></value>
                                        <next>
                                          <block type="pico_if">
                                            <mutation elseif="0" else="0" />
                                            <value name="IF0">
                                              <block type="cond_compare">
                                                <field name="OP">&lt;=</field>
                                                <value name="LEFT"><block type="val_var"><field name="VAR" id="vli">lives</field></block></value>
                                                <value name="RIGHT"><block type="val_number"><field name="NUM">0</field></block></value>
                                              </block>
                                            </value>
                                            <statement name="DO0">
                                              <block type="var_set">
                                                <field name="VAR" id="vst">state</field>
                                                <value name="VALUE"><block type="val_str"><field name="TEXT">over</field></block></value>
                                              </block>
                                            </statement>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
