<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vremain">remain</variable>
    <variable id="vstate">state</variable>
  </variables>
  <!-- remain = timer.remain(30)  →  if remain <= 0: state = "clear"  →  if remain < 10: draw red else: draw white -->
  <block type="var_set" x="20" y="20">
    <field name="VAR" id="vremain">remain</field>
    <value name="VALUE">
      <block type="py_module_call_val">
        <field name="MODULE">timer</field>
        <field name="FUNC">remain</field>
        <value name="ARG">
          <block type="val_number"><field name="NUM">30</field></block>
        </value>
      </block>
    </value>
    <next>
      <block type="pico_if">
        <mutation elseif="0" else="0" />
        <value name="IF0">
          <block type="cond_compare">
            <field name="OP">&lt;=</field>
            <value name="LEFT">
              <block type="val_var"><field name="VAR" id="vremain">remain</field></block>
            </value>
            <value name="RIGHT">
              <block type="val_number"><field name="NUM">0</field></block>
            </value>
          </block>
        </value>
        <statement name="DO0">
          <block type="var_set">
            <field name="VAR" id="vstate">state</field>
            <value name="VALUE">
              <block type="val_str"><field name="TEXT">clear</field></block>
            </value>
          </block>
        </statement>
        <next>
          <block type="pico_if">
            <mutation elseif="0" else="1" />
            <value name="IF0">
              <block type="cond_compare">
                <field name="OP">&lt;</field>
                <value name="LEFT">
                  <block type="val_var"><field name="VAR" id="vremain">remain</field></block>
                </value>
                <value name="RIGHT">
                  <block type="val_number"><field name="NUM">10</field></block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="game_draw_text">
                <value name="TEXT">
                  <block type="val_var"><field name="VAR" id="vremain">remain</field></block>
                </value>
                <value name="X"><block type="val_number"><field name="NUM">10</field></block></value>
                <value name="Y"><block type="val_number"><field name="NUM">10</field></block></value>
                <value name="COLOR">
                  <block type="colour_picker"><field name="COLOUR">#ff3c3c</field></block>
                </value>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="game_draw_text">
                <value name="TEXT">
                  <block type="val_var"><field name="VAR" id="vremain">remain</field></block>
                </value>
                <value name="X"><block type="val_number"><field name="NUM">10</field></block></value>
                <value name="Y"><block type="val_number"><field name="NUM">10</field></block></value>
                <value name="COLOR">
                  <block type="colour_picker"><field name="COLOUR">#ffffff</field></block>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
