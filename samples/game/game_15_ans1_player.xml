<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vpx">px</variable>
    <variable id="vsp">speed</variable>
  </variables>
  <!-- 課題4-16-1: player.py の move_x に speed 引数を追加 -->
  <block type="py_def_args2" x="20" y="20">
    <field name="NAME">move_x</field>
    <field name="PARAM1">px</field>
    <field name="PARAM2">speed=4</field>
    <statement name="BODY">
      <block type="pico_if">
        <mutation elseif="0" else="0" />
        <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_LEFT</field></block></value>
        <statement name="DO0">
          <block type="var_change">
            <field name="VAR" id="vpx">px</field>
            <value name="AMOUNT">
              <block type="py_math_op">
                <field name="OP">-</field>
                <value name="LEFT"><block type="val_number"><field name="NUM">0</field></block></value>
                <value name="RIGHT"><block type="val_var"><field name="VAR" id="vsp">speed</field></block></value>
              </block>
            </value>
          </block>
        </statement>
        <next>
          <block type="pico_if">
            <mutation elseif="0" else="0" />
            <value name="IF0"><block type="game_key_pressed"><field name="KEY">K_RIGHT</field></block></value>
            <statement name="DO0">
              <block type="var_change">
                <field name="VAR" id="vpx">px</field>
                <value name="AMOUNT"><block type="val_var"><field name="VAR" id="vsp">speed</field></block></value>
              </block>
            </statement>
            <next>
              <block type="pico_if">
                <mutation elseif="0" else="0" />
                <value name="IF0">
                  <block type="cond_compare">
                    <field name="OP">&lt;</field>
                    <value name="LEFT"><block type="val_var"><field name="VAR" id="vpx">px</field></block></value>
                    <value name="RIGHT"><block type="val_number"><field name="NUM">0</field></block></value>
                  </block>
                </value>
                <statement name="DO0">
                  <block type="var_set">
                    <field name="VAR" id="vpx">px</field>
                    <value name="VALUE"><block type="val_number"><field name="NUM">0</field></block></value>
                  </block>
                </statement>
                <next>
                  <block type="pico_if">
                    <mutation elseif="0" else="0" />
                    <value name="IF0">
                      <block type="cond_compare">
                        <field name="OP">&gt;</field>
                        <value name="LEFT"><block type="val_var"><field name="VAR" id="vpx">px</field></block></value>
                        <value name="RIGHT"><block type="val_number"><field name="NUM">592</field></block></value>
                      </block>
                    </value>
                    <statement name="DO0">
                      <block type="var_set">
                        <field name="VAR" id="vpx">px</field>
                        <value name="VALUE"><block type="val_number"><field name="NUM">592</field></block></value>
                      </block>
                    </statement>
                    <next>
                      <block type="py_return">
                        <value name="VALUE"><block type="val_var"><field name="VAR" id="vpx">px</field></block></value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
