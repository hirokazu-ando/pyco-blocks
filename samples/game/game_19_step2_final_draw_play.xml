<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="v19px">px</variable>
    <variable id="v19bs">bullets</variable>
    <variable id="v19b">b</variable>
  </variables>
  <block type="py_def_noarg" x="20" y="20">
    <field name="NAME" variabletype="function">draw_play</field>
    <statement name="BODY">
      <block type="game_draw_image">
        <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/player_ship.svg</field></block></value>
        <value name="X"><block type="val_var"><field name="VAR" id="v19px">px</field></block></value>
        <value name="Y"><block type="val_number"><field name="NUM">330</field></block></value>
        <value name="W"><block type="val_number"><field name="NUM">48</field></block></value>
        <value name="H"><block type="val_number"><field name="NUM">48</field></block></value>
        <next>
          <block type="py_for_list">
            <field name="VAR" id="v19b">b</field>
            <field name="LIST" id="v19bs">bullets</field>
            <statement name="DO">
              <block type="game_draw_image">
                <value name="URL"><block type="game_image_preset"><field name="IMG">assets/game-icons/bullet.svg</field></block></value>
                <value name="X">
                  <block type="py_list_get">
                    <field name="LIST" id="v19b">b</field>
                    <value name="INDEX"><block type="val_number"><field name="NUM">0</field></block></value>
                  </block>
                </value>
                <value name="Y">
                  <block type="py_list_get">
                    <field name="LIST" id="v19b">b</field>
                    <value name="INDEX"><block type="val_number"><field name="NUM">1</field></block></value>
                  </block>
                </value>
                <value name="W"><block type="val_number"><field name="NUM">16</field></block></value>
                <value name="H"><block type="val_number"><field name="NUM">24</field></block></value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
