<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="vnum">num_enemies</variable>
  </variables>
  <!-- num_enemies = min(5, 1 + int(timer.elapsed() // 10)) -->
  <block type="var_set" x="20" y="20">
    <field name="VAR" id="vnum">num_enemies</field>
    <value name="VALUE">
      <block type="py_min2">
        <value name="A">
          <block type="val_number"><field name="NUM">5</field></block>
        </value>
        <value name="B">
          <block type="py_math_op">
            <field name="OP">+</field>
            <value name="LEFT">
              <block type="val_number"><field name="NUM">1</field></block>
            </value>
            <value name="RIGHT">
              <block type="py_int">
                <value name="VALUE">
                  <block type="py_math_op">
                    <field name="OP">//</field>
                    <value name="LEFT">
                      <block type="py_module_call_val">
                        <field name="MODULE">timer</field>
                        <field name="FUNC">elapsed</field>
                      </block>
                    </value>
                    <value name="RIGHT">
                      <block type="val_number"><field name="NUM">10</field></block>
                    </value>
                  </block>
                </value>
              </block>
            </value>
          </block>
        </value>
      </block>
    </value>
  </block>
</xml>
