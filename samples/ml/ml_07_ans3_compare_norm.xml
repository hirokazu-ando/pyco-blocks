<?xml version="1.0" encoding="UTF-8"?>
<xml xmlns="https://developers.google.com/blockly/xml">
  <variables>
    <variable id="var_X">X</variable>
    <variable id="var_y">y</variable>
    <variable id="var_X_tr">X_tr</variable>
    <variable id="var_X_te">X_te</variable>
    <variable id="var_y_tr">y_tr</variable>
    <variable id="var_y_te">y_te</variable>
    <variable id="var_clf1">clf1</variable>
    <variable id="var_pred1">pred1</variable>
    <variable id="var_Xn">X_norm</variable>
  </variables>
  <block type="ml_import" id="b0" x="30" y="30">
    <next>
      <block type="var_set" id="b1">
        <field name="VAR" id="var_X">X</field>
        <value name="VALUE">
          <block type="ml_data_2d"><field name="DATA">[[160,55,20],[175,70,22],[155,48,18],[185,80,25],[165,60,21],[172,68,23]]</field></block>
        </value>
        <next>
          <block type="var_set" id="b2">
            <field name="VAR" id="var_y">y</field>
            <value name="VALUE">
              <block type="ml_label_list"><field name="DATA">['A','B','A','B','A','B']</field></block>
            </value>
            <next>
              <block type="ml_split" id="b3">
                <field name="X_TR" id="var_X_tr">X_tr</field>
                <field name="X_TE" id="var_X_te">X_te</field>
                <field name="Y_TR" id="var_y_tr">y_tr</field>
                <field name="Y_TE" id="var_y_te">y_te</field>
                <value name="X"><block type="val_var" id="bvX"><field name="VAR" id="var_X">X</field></block></value>
                <value name="Y"><block type="val_var" id="bvy"><field name="VAR" id="var_y">y</field></block></value>
                <field name="RATIO">0.3</field>
                <next>
                  <block type="ml_knn" id="b4">
                    <field name="VAR" id="var_clf1">clf1</field>
                    <field name="K">3</field>
                    <next>
                      <block type="ml_fit" id="b5">
                        <value name="MODEL"><block type="val_var" id="bv1"><field name="VAR" id="var_clf1">clf1</field></block></value>
                        <value name="X_TRAIN"><block type="val_var" id="bv2"><field name="VAR" id="var_X_tr">X_tr</field></block></value>
                        <value name="Y_TRAIN"><block type="val_var" id="bv3"><field name="VAR" id="var_y_tr">y_tr</field></block></value>
                        <next>
                          <block type="ml_predict_stmt" id="b6">
                            <field name="VAR" id="var_pred1">pred1</field>
                            <value name="MODEL"><block type="val_var" id="bv4"><field name="VAR" id="var_clf1">clf1</field></block></value>
                            <value name="X_TEST"><block type="val_var" id="bv5"><field name="VAR" id="var_X_te">X_te</field></block></value>
                            <next>
                              <block type="py_custom_stmt" id="cs1">
                                <field name="CODE">print('正規化なし:', pyco_ml.accuracy(y_te, pred1))</field>
                                <next>
                                  <block type="var_set" id="b7">
                                    <field name="VAR" id="var_Xn">X_norm</field>
                                    <value name="VALUE">
                                      <block type="py_call_val" id="bpnorm">
                                        <field name="NAME" variabletype="function">pyco_ml.normalize</field>
                                        <value name="ARG"><block type="val_var" id="bvXn"><field name="VAR" id="var_X">X</field></block></value>
                                      </block>
                                    </value>
                                    <next>
                                      <block type="py_custom_stmt" id="cs2">
                                        <field name="CODE">X_tr2, X_te2, y_tr2, y_te2 = pyco_ml.train_test_split(X_norm, y, 0.3)</field>
                                        <next>
                                          <block type="py_custom_stmt" id="cs3">
                                            <field name="CODE">clf2 = pyco_ml.KNN(3)</field>
                                            <next>
                                              <block type="py_custom_stmt" id="cs4">
                                                <field name="CODE">clf2.fit(X_tr2, y_tr2)</field>
                                                <next>
                                                  <block type="py_custom_stmt" id="cs5">
                                                    <field name="CODE">pred2 = clf2.predict(X_te2)</field>
                                                    <next>
                                                      <block type="py_custom_stmt" id="cs6">
                                                        <field name="CODE">print('正規化あり:', pyco_ml.accuracy(y_te2, pred2))</field>
                                                      </block>
                                                    </next>
                                                  </block>
                                                </next>
                                              </block>
                                            </next>
                                          </block>
                                        </next>
                                      </block>
                                    </next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </next>
  </block>
</xml>
